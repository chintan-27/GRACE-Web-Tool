# =============================================================================
# CROWN API v2 — .env (used for both local dev AND Docker deployment)
# docker-compose is run with --env-file ./api_v2/.env so these variable names
# are used directly for volume mount source paths.
# =============================================================================

# Host paths — directories that exist on the server and are bind-mounted
# into the API container. Used by docker-compose for volume substitution.
MODELS_HOST_PATH=/home/chintan/wws_v2/api_v2/models
FREESURFER_LICENSE_PATH=/home/chintan/licenses/freesurfer.txt

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# GPU
GPU_COUNT=4
JOB_TIMEOUT_SECONDS=3600

# Security
JWT_SECRET=change_me_in_production
HMAC_SECRET=change_me_hmac_in_production

# FreeSurfer
FREESURFER_HOME=/usr/local/freesurfer

# ROAST / MATLAB
# ROAST_BUILD_DIR: directory containing the compiled ROAST standalone (run_roast*)
ROAST_BUILD_DIR=/home/chintan/roast11/build
# MATLAB_RUNTIME: path to the MATLAB Component Runtime matching the ROAST build
MATLAB_RUNTIME=/home/chintan/MATLAB/MATLAB_Runtime/R2025b
ROAST_MAX_WORKERS=2
ROAST_TIMEOUT_SECONDS=7200

# SimNIBS
# SIMNIBS_HOME: top-level SimNIBS installation directory (contains bin/charm)
SIMNIBS_HOME=/home/chintan/SimNIBS-4.5
SIMNIBS_N_THREADS=8
SIMNIBS_MAX_WORKERS=1
SIMNIBS_TIMEOUT_SECONDS=10800
# MNI_TEMPLATE: leave blank to auto-discover from SimNIBS installation
MNI_TEMPLATE=

# Email notifications (optional — leave blank to disable)
# SMTP_HOST: your SMTP server (e.g. smtp.gmail.com, smtp.sendgrid.net)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@crown-tool.example.com
# FRONTEND_URL: public URL of the frontend, used in restore email links
FRONTEND_URL=http://localhost:3000
# How long (seconds) a restore link stays valid — default 6 hours
NOTIFY_TOKEN_TTL=21600
