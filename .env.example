# =============================================================================
# CROWN – docker-compose environment configuration
# Copy this file to .env and fill in the values for your server.
# =============================================================================

# -----------------------------------------------------------------------------
# Security (REQUIRED — change before deploying)
# -----------------------------------------------------------------------------
JWT_SECRET=change_me_in_production
HMAC_SECRET=change_me_hmac_in_production

# -----------------------------------------------------------------------------
# GPU
# -----------------------------------------------------------------------------
GPU_COUNT=4
JOB_TIMEOUT_SECONDS=3600

# -----------------------------------------------------------------------------
# Host paths — directories that exist on the server and are bind-mounted
# into the API container (read-only where marked :ro in docker-compose.yml)
# -----------------------------------------------------------------------------

# Pre-trained model weights directory
MODELS_HOST_PATH=/home/chintan/wws_v2/api_v2/models

# FreeSurfer license file (single file, not the whole installation)
FREESURFER_LICENSE_PATH=/home/chintan/licenses/freesurfer.txt

# ROAST-11 compiled standalone binary directory
# Should contain run_roast.sh / run_roast (the MCR-linked executable)
ROAST_HOST_PATH=/home/chintan/roast11/build

# MATLAB Component Runtime (MCR) — the release must match the ROAST build
# e.g. R2025b, R2024b.  The directory should contain bin/, runtime/, etc.
MATLAB_RUNTIME_HOST=/home/chintan/MATLAB/MATLAB_Runtime/R2025b

# SimNIBS installation directory
# Should contain bin/charm, bin/simnibs, simnibs_env/, etc.
# Corresponds to the directory produced by the SimNIBS installer.
SIMNIBS_HOST_PATH=/home/chintan/SimNIBS-4.5.0

# -----------------------------------------------------------------------------
# ROAST tuning
# -----------------------------------------------------------------------------
ROAST_MAX_WORKERS=2
ROAST_TIMEOUT_SECONDS=7200

# -----------------------------------------------------------------------------
# SimNIBS tuning
# -----------------------------------------------------------------------------
SIMNIBS_N_THREADS=8
SIMNIBS_MAX_WORKERS=1
SIMNIBS_TIMEOUT_SECONDS=10800

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
# Public URL of the backend API — baked into the Next.js build at image-build time
NEXT_PUBLIC_API_URL=http://10.15.224.253:8000
