# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# GPU Configuration
GPU_COUNT=4

# Security (change these in production!)
JWT_SECRET=change_me_in_production
HMAC_SECRET=change_me_hmac_in_production

# Job Configuration
JOB_TIMEOUT_SECONDS=3600

# FreeSurfer (path to FreeSurfer installation)
FREESURFER_HOME=/usr/local/freesurfer

# SimNIBS installation directory (contains bin/charm, simnibs_env/, etc.)
# Can be set as either SIMNIBS_HOME or SIM_NIBS (both are supported)
SIM_NIBS=/home/user/SimNIBS-4.5.0
# SIMNIBS_HOME=/home/user/SimNIBS-4.5.0
